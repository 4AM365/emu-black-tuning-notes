# Source material — not for tracking
# (source books moved to shared ../../agentic-library/engine-dynamics/)
corpus/

# Logs are large — keep locally, don't commit unless small
supra/logs/*.csv
!supra/logs/.gitkeep

# Raw OCR page cache — large intermediate files, regenerate with ocr_extract.py
maximum-boost/_raw_ocr/

# Never commit source PDFs
*.pdf

# Python cache
__pycache__/
*.pyc

# Script scratch / regenerable outputs (don't scatter at repo root)
_tmp/
/err.txt
/out.txt
/egt_results.txt

# Nested standalone tools — organizational nesting, not a merge. Keep out of this repo.
# emubt_breakout keeps its own git history + remote (github.com/4AM365/emubt_breakout).
# emub_analysis is local-only (Flask app + venv), kept for local LLM tooling.
tools/emubt_breakout/
tools/emub_analysis/
